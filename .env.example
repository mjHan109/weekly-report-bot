# ═══════════════════════════════════════════════════════════════════════════════
# Weekly Report Automation — Environment Variables (Slack + Gmail SMTP)
# Copy this file to .env and fill in real values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
# Set to "true" for development (enables /docs, verbose logging)
DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# Development: sqlite+aiosqlite:///./dev.db
# Production:  postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ── Slack Bot ─────────────────────────────────────────────────────────────────
# Bot User OAuth Token (OAuth & Permissions > Bot Token)
SLACK_BOT_TOKEN=your-slack-bot-token
# App Signing Secret (Basic Information > App Credentials)
SLACK_SIGNING_SECRET=replace-with-signing-secret

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Gmail 계정 주소
GMAIL_USER=yourname@gmail.com
# Gmail 앱 비밀번호 (Google 계정 > 보안 > 앱 비밀번호에서 발급)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# 메일 발신자 표시 이름 (회사 이메일로 설정 가능)
MAIL_FROM=yourname@company.com
# 기본 수신자 이메일
MAIL_TO=recipient@company.com

# ── Scheduler HMAC ─────────────────────────────────────────────────────────────
# 스케줄러 인증용 공유 시크릿
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SCHEDULER_HMAC_SECRET=replace-with-a-32-byte-hex-secret

# ── Anthropic LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Timezone ──────────────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Seoul

# ── Cron 참고 (앱이 직접 읽지 않음) ──────────────────────────────────────────
# 목요일 10:00 KST 리마인더: 0 1 * * 4
# 목요일 13:00 KST 마감:     0 4 * * 4
