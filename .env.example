# ═══════════════════════════════════════════════════════════════════════════════
# Teams Weekly Report Automation — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
# Set to "true" for development (enables /docs, verbose logging)
DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# Production: postgresql+asyncpg://user:password@host:5432/dbname
# Development/CI: sqlite+aiosqlite:///./dev.db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/teams_reports

# ── Microsoft Graph / Bot ──────────────────────────────────────────────────────
# Azure AD app registration credentials
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# OAuth redirect URI — must match the value registered in Azure AD app registration
# e.g. https://yourdomain.com/auth/callback (prod) or http://localhost:8000/auth/callback (dev)
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# Bot Framework App ID & Password
BOT_APP_ID=your-bot-app-id
BOT_APP_PASSWORD=your-bot-app-password

# ── Scheduler HMAC ─────────────────────────────────────────────────────────────
# Shared secret for HMAC-SHA256 verification of scheduler requests
# (X-Scheduler-Sig header). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SCHEDULER_HMAC_SECRET=replace-with-a-32-byte-hex-secret

# ── Admin / Team Lead Seeding ─────────────────────────────────────────────────
# Comma-separated list of Azure AD Object IDs to seed as initial team leads
# REQUIRED — app will refuse to start if empty
INITIAL_ADMIN_USER_IDS=aad-object-id-1,aad-object-id-2

# ── Anthropic LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model to use for report aggregation drafting
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Timezone / Scheduler ──────────────────────────────────────────────────────
# Canonical timezone for deadline computation (do not change)
APP_TIMEZONE=Asia/Seoul

# Cron expressions for the external scheduler (informational — not read by app)
# Thursday 10:00 KST reminder:  0 1 * * 4
# Thursday 13:00 KST deadline:  0 4 * * 4

# ── Slack Bot ─────────────────────────────────────────────────────────────────
# Bot User OAuth Token (OAuth & Permissions > Bot Token)
SLACK_BOT_TOKEN=xoxb-...
# App Signing Secret (Basic Information > App Credentials)
SLACK_SIGNING_SECRET=replace-with-signing-secret
